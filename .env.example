# ============================================================
# Telegram Video-Matic — Environment Configuration
# ============================================================
# Copy this file to .env and fill in secrets.
# Secrets are REQUIRED; others have sensible defaults.

# REQUIRED: Encryption key for storing api_id, api_hash, and Telethon session string.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
TVM_SECRET_KEY=your-secret-key-here

# OPTIONAL: Web UI password. If unset, app is open on LAN (logged warning in startup).
# Recommend: strong random string or leave unset for trusted networks only.
TVM_APP_PASSWORD=your-app-password

# Database URL (usually no need to change; /data is a mounted volume).
DATABASE_URL=sqlite+aiosqlite:////data/tvm.sqlite

# Media download root (usually no need to change; /media is a mounted volume).
MEDIA_ROOT=/media

# Poll interval in seconds (default: 300 = 5 min; runtime-tunable via API).
POLL_INTERVAL_SEC=300

# Max concurrent downloads (default: 3; runtime-tunable via API).
MAX_CONCURRENT_DOWNLOADS=3

# Retention period in days (default: 90; runtime-tunable via API).
RETENTION_DAYS=90

# Retention disk percentage threshold (default: 80%; runtime-tunable via API).
RETENTION_DISK_PCT=80

# Timezone for schedule-day evaluation (default: UTC).
# Examples: America/New_York, Europe/London, Asia/Tokyo
TZ=UTC

# FastAPI debug mode (optional; default: false). Set to true only for local dev.
DEBUG=false
